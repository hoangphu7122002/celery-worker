# Environment: dev, test, prod, production
ENVIRONMENT=dev

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cursor_worker
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
CONVERSATION_MODEL=gpt-4o-mini

# Zendesk
ZENDESK_SUBDOMAIN=spartan-95037
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
ZENDESK_WEBHOOK_ENABLED=true

# ngrok for Zendesk webhook (optional). Reserve domain at dashboard.ngrok.com
NGROK_DOMAIN=

# LLM rate limit: when enabled, caps OpenAI calls per sync/webhook run (saves cost in dev).
# Set ZENDESK_LLM_LIMIT_ENABLED=true to enable; when false, LLM runs for all tickets.
ZENDESK_LLM_LIMIT_ENABLED=false
ZENDESK_LLM_LIMIT_TICKETS_PER_RUN=5
ZENDESK_LLM_LIMIT_TTL_SECONDS=600

# Celery worker (docker)
CELERY_CONCURRENCY=4   # processes per container
NUM_WORKERS=3        # worker containers (use --scale worker=N for docker compose up)
